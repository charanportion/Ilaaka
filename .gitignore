# Dependencies
node_modules/

# Environment — never commit real keys
.env
.env.local
.env*.local
supabase/.env.local

# Firebase / Google Services — contains live API keys, never commit
apps/mobile/google-services.json
apps/mobile/android/app/google-services.json
apps/mobile/GoogleService-Info.plist
apps/mobile/ios/**/GoogleService-Info.plist

# Android keystores — production signing material
*.keystore
*.jks
!apps/mobile/android/app/debug.keystore

# Supabase local dev
supabase/.temp/

# OS
.DS_Store
Thumbs.db

